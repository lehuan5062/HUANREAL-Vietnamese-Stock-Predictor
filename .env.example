# Copy this file to `.env` (in the same folder) and fill in your keys.
# `.env` is loaded automatically when claude/gemini modes run.

# Anthropic Claude API key — enables autonomous claude mode (web_search tool).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini API key — enables autonomous gemini mode (google_search grounding).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
